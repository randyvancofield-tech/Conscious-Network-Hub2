# Cloudflare Pages frontend environment.
VITE_BACKEND_URL=https://api.example.com
VITE_IDENTITY_CHALLENGE_URL=https://api.example.com/api/identity/challenge
VITE_IDENTITY_VERIFY_URL=https://api.example.com/api/identity/verify
VITE_IDENTITY_SESSION_URL=https://api.example.com/api/identity/session
VITE_IDENTITY_LOGOUT_URL=https://api.example.com/api/identity/logout
VITE_PROFILE_INTEGRITY_VERIFY_URL=https://api.example.com/api/integrity/profile/verify
VITE_PROFILE_INTEGRITY_RECORD_URL=https://api.example.com/api/integrity/profile/record
VITE_BLOCKCHAIN_NETWORK_ID=11155111
VITE_IPFS_GATEWAY=https://ipfs.io/ipfs

# Render/backend production environment names.
# Set these in Render or the managed backend secret store, not in Cloudflare Pages.
# AUTH_TOKEN_SECRET=<strong-random-server-secret>
# DATABASE_URL=postgresql://<neon-pooled-host>/<db>?sslmode=require
# DATABASE_POOL_MODE=transaction
# AUTH_PERSISTENCE_BACKEND=shared_db
# SENSITIVE_DATA_KEY=<strong-random-server-secret>
# UPLOAD_OBJECT_KEY_SECRET=<dedicated-strong-random-server-secret>
# TRUST_PROXY=1
# PUBLIC_BASE_URL=https://api.example.com
# SERVER_ALLOWED_HOSTS=api.example.com,conscious-network-backend.onrender.com
# UPLOAD_LEGACY_OBJECT_KEY_SECRET=<previous-upload-key-secret-migration-only>

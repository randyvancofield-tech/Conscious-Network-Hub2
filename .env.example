# Frontend environment template
# Local backend default
VITE_BACKEND_URL=http://localhost:3001
# Safety default: in development, ignore remote backend URLs unless explicitly allowed.
VITE_ALLOW_REMOTE_BACKEND_IN_DEV=false
# Identity verification/session endpoints
VITE_IDENTITY_CHALLENGE_URL=/api/identity-security/challenge
VITE_IDENTITY_VERIFY_URL=/api/identity-security/verify
VITE_IDENTITY_SESSION_URL=/api/identity-security/session
VITE_IDENTITY_LOGOUT_URL=/api/identity-security/logout
VITE_PROFILE_INTEGRITY_VERIFY_URL=/api/integrity/profile/verify
VITE_PROFILE_INTEGRITY_RECORD_URL=/api/integrity/profile/record

# Blockchain network (integrity infrastructure)
VITE_BLOCKCHAIN_NETWORK_ID=1

# Admin/provider wallet authentication transport.
# Must match backend PROVIDER_WALLET_CHAIN_ID when set.
VITE_PROVIDER_WALLET_CHAIN_ID=1
# Optional RPC endpoint used by MetaMask Connect for the auth chain.
# Mainnet falls back to https://cloudflare-eth.com when this is omitted.
VITE_PROVIDER_WALLET_RPC_URL=
VITE_ETHEREUM_MAINNET_RPC_URL=

# Public IPFS gateway for technical debug record links
VITE_IPFS_GATEWAY=https://ipfs.io/ipfs

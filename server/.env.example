# Backend environment template (no secrets)
# Shared DB mode is required outside tests.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conscious_network_hub"
# Production Neon should use the pooled connection string, for example a -pooler host.
DATABASE_POOL_MODE=transaction
AUTH_PERSISTENCE_BACKEND=shared_db
DATABASE_PROVIDER=postgresql
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
VERTEX_AI_MODEL=gemini-1.5-flash-001
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
HSTS_ALLOWED_HOSTS=
HSTS_MAX_AGE_SECONDS=31536000
STRIPE_SECRET_KEY=sk_test_replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_webhook_secret
STRIPE_PRICE_FREE=price_1TR1ErE9ozmNlTR0peEA7Ska
STRIPE_PRICE_GUIDED=price_1TR1HpE9ozmNlTR0To2XvmuW
STRIPE_PRICE_ACCELERATED=price_1TR1JTE9ozmNlTR090ftqnGn
STRIPE_MODE=test
STRIPE_SUCCESS_URL=http://localhost:5173/verify-session?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/?checkout=cancel
EMAIL_FROM=noreply@conscious-network.org
ADMIN_NOTIFICATION_EMAIL=higherconscious.network1@gmail.com
ENABLE_PASSWORD_RESET=true
EMAIL_DELIVERY_ENABLED=false
REQUIRE_EMAIL_DELIVERY=false
# Member 2FA is removed from the active launch path.
ENABLE_USER_2FA=false
# Optional Gmail/service auth. Required only when EMAIL_DELIVERY_ENABLED=true or REQUIRE_EMAIL_DELIVERY=true.
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Optional legacy SMS delivery. Twilio is not required for member sign-in or onboarding.
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567
RATE_LIMIT_MAX=100
# AI runtime chain. "auto" tries Ollama, OpenRouter, Groq, then local safe fallback.
AI_PROVIDER=auto
AI_PROVIDER_TIMEOUT_MS=15000
AI_LOCAL_FALLBACK_ENABLED=true
AI_CRAWLER_ENABLED=true
AI_CRAWLER_INTERVAL_MS=600000
AI_ENABLE_OLLAMA=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=your-openai-api-key
AUTH_TOKEN_SECRET=replace-with-strong-random-secret
IDENTITY_SESSION_SECRET=replace-with-strong-random-secret
IDENTITY_SESSION_TTL_SECONDS=2592000
IDENTITY_CHALLENGE_TTL_SECONDS=300
SENSITIVE_DATA_KEY=replace-with-32-byte-key-or-long-passphrase
ADMIN_DIAGNOSTICS_KEY=replace-with-admin-diagnostics-key
# Optional one-time credential used only when manually creating higherconscious.network1@gmail.com
# with `npm --prefix server run admin:ensure-provider-crm`. Do not set permanently.
PROVIDER_CRM_ADMIN_INITIAL_PASSWORD=
# Startup retries for the provider CRM admin repair step when Neon is briefly unreachable.
PROVIDER_CRM_ADMIN_BOOTSTRAP_MAX_ATTEMPTS=3
PROVIDER_CRM_ADMIN_BOOTSTRAP_RETRY_MS=1500
# Optional founder/admin wallet for Administrative Access gasless signature login.
# Store only the public 0x address here. Never store a seed phrase or private key.
PROVIDER_CRM_ADMIN_WALLET_ADDRESS=
# In production this defaults to false unless explicitly enabled as break-glass recovery.
ENABLE_ADMIN_PASSWORD_FALLBACK=false
PROVIDER_CRM_ENABLED_TOOLS=
PROVIDER_CRM_DISABLED_TOOLS=
# Optional native Conscious Meetings WebRTC network config.
# STUN keeps the no-vendor/free path working for many users; TURN is optional for restrictive networks.
MEETING_STUN_URLS=stun:stun.l.google.com:19302
MEETING_TURN_URLS=
MEETING_TURN_USERNAME=
MEETING_TURN_CREDENTIAL=
AUDIT_LOG_FILE=./data/audit-events.log
AUDIT_LOG_STDOUT_ONLY=false
UPLOAD_MAX_BYTES=26214400
# Optional override for signed upload object keys. Defaults to SENSITIVE_DATA_KEY.
UPLOAD_OBJECT_KEY_SECRET=
# Legacy unsigned upload keys are denied by default. Enable only during a planned migration window.
UPLOAD_ALLOW_LEGACY_PUBLIC_OBJECTS=false
UPLOAD_ALLOW_LEGACY_AUTHENTICATED_OBJECTS=false
HCN_PROFILE_ANCHOR_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
HCN_PROFILE_ANCHOR_CHAIN_ID=1
INTEGRITY_ANCHOR_RPC_URL=
INTEGRITY_ANCHOR_PRIVATE_KEY=
IPFS_UPLOAD_PROVIDER=pinata
IPFS_GATEWAY=https://ipfs.io/ipfs
PINATA_JWT=
PINATA_PIN_JSON_URL=https://api.pinata.cloud/pinning/pinJSONToIPFS
INFURA_PROJECT_ID=
INFURA_PROJECT_SECRET=
INFURA_ADD_URL=https://ipfs.infura.io:5001/api/v0/add?pin=true
IPFS_PIN_JSON_URL=
IPFS_PIN_JSON_TOKEN=

